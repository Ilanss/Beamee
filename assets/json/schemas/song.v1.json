{
  "$id": "https://beamee.app/schemas/song.v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Beamee Song (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "authors",
    "collections",
    "sections",
    "arrangement"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "authors": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "collections": {
      "type": "array",
      "items": { "$ref": "#/$defs/collectionMembership" }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    },
    "arrangement": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/arrangementItem" }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "language": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "sectionType": {
      "type": "string",
      "enum": [
        "verse",
        "chorus",
        "pre-chorus",
        "bridge",
        "intro",
        "outro",
        "tag",
        "other"
      ]
    },
    "collectionMembership": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "collectionId"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "collectionId": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "reference": { "type": "string", "minLength": 1 },
        "number": { "type": "integer", "minimum": 1 }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "lines"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "type": { "$ref": "#/$defs/sectionType" },
        "title": { "type": "string", "minLength": 1 },
        "lines": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "arrangementItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sectionId"],
      "properties": {
        "sectionId": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": { "type": "string", "minLength": 1 }
      }
    }
  }
}
